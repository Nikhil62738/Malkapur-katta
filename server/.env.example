# ---- Server ----
PORT=5000

# ---- Database ----
# Local MongoDB or a MongoDB Atlas connection string
MONGODB_URI=mongodb://127.0.0.1:27017/malkapur_katta

# ---- Auth ----
# Use a long, random secret in production
JWT_SECRET=change-this-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# ---- CORS ----
# Comma-separated list of allowed frontend origins. Use * to allow all (dev only).
CORS_ORIGIN=http://localhost:5173

# ---- Default admin (created by `npm run seed`) ----
# IMPORTANT: keep the word "admin" in the email, or change AuthContext's admin check.
ADMIN_EMAIL=admin@malkapurkatta.com
ADMIN_PASSWORD=Admin@12345
ADMIN_NAME=Malkapur Katta Admin

# ---- Cloudinary (image/video uploads) ----
# Leave blank to disable uploads (the admin panel will show an error on upload).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
CLOUDINARY_FOLDER=malkapur-katta
